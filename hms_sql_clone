-- VISIT & ADMISSION

CREATE TABLE Visit
(
    VisitId INT PRIMARY KEY IDENTITY(1,1),
    PatientCategoryID INT,
    PatientId INT,
    DoctorID INT,
    UnitId INT,
    VisitDate DATETIME,
    OPDNumber INT,
    AddedBy INT,
    UpdatedBy INT
)
GO

CREATE TABLE Admission
(
    AdmissionId INT PRIMARY KEY IDENTITY(1,1),
    PatientCategoryID INT,
    PatientId INT,
    UnitId INT,
    DoctorID INT,
    AdmissionDate DATETIME,
    IPDNumber INT,
