CREATE TABLE Patient
(
    PatientId INT PRIMARY KEY IDENTITY(1,1),
    FirstName VARCHAR(100),
    MiddleName VARCHAR(100),
    LastName VARCHAR(100),
    GenderID INT,
    DateOfBirth DATE,
