-- Staff Insert

DECLARE @MinDeptId INT
DECLARE @MaxDeptId INT

SELECT @MinDeptId=MIN(DepartmentId),
       @MaxDeptId=MAX(DepartmentId)
FROM Department
WHERE IsClinical=0

