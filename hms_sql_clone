    DoctorId INT,
    DischargeDate DATETIME,
    AddedBy INT,
    UpdatedBy INT
)
GO
-- BILLING

CREATE TABLE Charge
(
    ChargeId INT PRIMARY KEY IDENTITY(1,1),
    VisitId INT NULL,
    AdmissionId INT NULL,
    ServiceId INT,
    Rate DECIMAL(18,2),
    Amount DECIMAL(18,2),
    Quantity INT,
    Concession DECIMAL(18,2) DEFAULT 0,
    AddedBy INT,
    UpdatedBy INT
)
GO

CREATE TABLE Bill
(
    BillId INT PRIMARY KEY IDENTITY(1,1),
    VisitId INT NULL,
    AdmissionId INT NULL,
    TotalAmount DECIMAL(18,2),
    Concession DECIMAL(18,2),
