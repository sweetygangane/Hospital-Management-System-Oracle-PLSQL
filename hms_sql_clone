BEGIN

    SET @i=1

    WHILE(@i<=10)
    BEGIN

        INSERT INTO Staff
        (
            DepartmentID,
            FirstName,
            MiddleName,
            LastName,
            GenderID,
            DateOfBirth,
            ContactNo1,
            ContactNo2,
            Email,
            AddressLine1,
            AddressLine2,
            Pincode,
            CityID,
            AddedBy,
            UpdatedBy
        )
        VALUES
        (
            @MinDeptId,
            'SFname-'+CAST(@MinDeptId AS VARCHAR(5))+'-'+CAST(@i AS VARCHAR(5)),
            'SMname-'+CAST(@MinDeptId AS VARCHAR(5))+'-'+CAST(@i AS VARCHAR(5)),
            'SLname-'+CAST(@MinDeptId AS VARCHAR(5))+'-'+CAST(@i AS VARCHAR(5)),
            (SELECT TOP 1 GenderId FROM Gender ORDER BY NEWID()),
            DATEADD(DAY,-10000,GETDATE()),
            '1234567890',
            '1234567890',
            'staff'+CAST(@i AS VARCHAR)+'@gmail.com',
            'Address Line 1',
            'Address Line 2',
            '123456',
            (SELECT TOP 1 CityId FROM City ORDER BY NEWID()),
            1,
            1
        )

        SET @i=@i+1
    END

    SET @MinDeptId=@MinDeptId+1
END

